#
# Server configuration
#
HOST                = "localhost" # Where to host the backend. Default: localhost
PORT                = 8000 # Port to run the backend on. Default: 8000
FRONTEND_URL        = "http://localhost:4321" # Where the frontend is hosted. Default: http://localhost:4321

#
# LLM Config & API Keys
#
DEFAULT_PROVIDER    = groq # Default LLM provider to use. No need to change unless you only want to use gemini. Options: groq, gemini

GROQ_API_KEY        = ultra.secret-key-you-need-to-replace # Replace with your Groq API key
GROQ_MODEL_NAME     = "qwen/qwen3.6-27b" # Main model used for answer generation. Default: qwen/qwen3.6-27b
GROQ_ROUTER_MODEL   = "llama-3.1-8b-instant" # Lightweight model used for query routing. Smaller than the main model to reduce token usage. Default: llama-3.1-8b-instant

GEMINI_API_KEY      = ultra.secret-key-you-need-to-replace # Replace with your Google AIStudio API key
GEMINI_MODEL_NAME   = "gemini-3.5-flash" # Main model used for answer generation. Default: gemini-3.5-flash
GEMINI_ROUTER_MODEL = "gemini-3.1-flash-lite" # Lightweight model used for query routing. Smaller than the main model to reduce token usage. Default: gemini-3.1-flash-lite

#
# RAG
#
DOCUMENTS_PATH      = ../documents # Path to the directory where the documents are stored
FAISS_INDEX_PATH    = ./faiss_index # Path to the directory where the FAISS index is stored. Doesn't need to exist beforehand.
EMBEDDINGS_MODEL    = sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 # Embeddings model used to create vector representations of the documents
CHUNK_SIZE          = 500 # Size of each chunk when splitting the documents
CHUNK_OVERLAP       = 50 # Overlap between chunks when splitting the documents